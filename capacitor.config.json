{
  "appId": "com.mse.player",
  "appName": "Music Subscription Escape",
  "webDir": "www",
  "server": {
    "allowNavigation": ["*"]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "Filesystem": {
      "requestPermissions": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#000000"
  },
  "backgroundMode": {
    "enable": true
  }
}
